Q20-Ali ki salary 55000 kar dein.
UPDATE Customers
SET Salary = 55000
WHERE Name = 'Ali';
Q21-Ahmed ka city Multan kar dein.
UPDATE Customers
SET City = 'Multan'
WHERE Name = 'Ahmed'
Q22-CustomerID = 7 delete karein.
DELETE FROM Customers
WHERE CustomerID = 7;
Q23-Age 21 wala customer delete karein.
DELETE FROM Customers
WHERE Age = 21;
Q24-Top 3 customers show karein.
SELECT * FROM customers
LIMIT 3;
SELECT TOP 3 * FROM customers;
Q25-Top 2 highest salaries show karein.
SELECT * FROM customers
ORDER BY Salary DESC 
LIMIT 2;
SELECT TOP 2 * FROM customers 
ORDER BY Salary DESC;
Q26-Maximum salary find karein.
SELECT MAX(Salary) 
FROM customers;
Q27-Minimum salary find karein.
SELECT MIN(Salary) 
FROM customers;
Q28-Total customers count karein.
SELECT COUNT(*) AS total_customers 
FROM Customers;
Q29-Sab salaries ka total nikaalein.
SELECT SUM(Salary) 
FROM Customers;
Q30-Average salary nikaalein.
SELECT AVG(Salary) 
FROM Customers;
Q31-Jin ka naam A se start hota hai.
SELECT * 
FROM Customers 
WHERE Name LIKE 'A%';
Q32-Jin ka naam a par end hota hai.
SELECT * 
FROM Customers 
WHERE Name LIKE '%a';
Q33-Jin ke naam me "li" aata ho.
SELECT * 
FROM Customers 
WHERE Name LIKE '%li%';
Q34-City Lahore se start ho.
SELECT * 
FROM Customers 
WHERE City LIKE 'Lahore%';
Q35-5 letters ke names show karein.
SELECT * 
FROM Customers 
WHERE len(Name) = 5; 

