Q1-Sab customers ka data show karein.
SELECT * 
FROM Customers;
Q2-Sirf Name aur City show karein.
SELECT Name,City 
FROM Customers; 
Q3-Sirf Salary column show karein.
SELECT Salary 
FROM Customers;
Q4-Unique cities show karein.
SELECT DISTINCT(City) 
FROM Customers;
Q5-Unique ages show karein.
SELECT DISTINCT(Age) 
FROM Customers;
Q6-Karachi ke customers show karein.
SELECT * 
FROM Customers 
WHERE City = 'Karachi';
Q7-Salary 50000 se zyada walay customers show karein.
SELECT * 
FROM Customers 
WHERE Salary > 50000;
Q8-Age 23 se kam walay customers show karein.
SELECT * 
FROM Customers 
WHERE Age < 23;
Q9-Salary ascending order me show karein.
SELECT * 
FROM Customers 
ORDER BY Salary ASC;
Q10-Salary descending order me show karein.
SELECT * 
FROM Customers 
ORDER BY Salary DESC;
Q11-Name alphabetically show karein.
SELECT * 
FROM Customers 
ORDER BY Name ASC;
Q12-Karachi ke customers jinki salary 50000 se zyada hai.
SELECT * 
FROM Customers 
WHERE City = 'Karachi' 
AND Salary > 50000;
Q13-Lahore ke customers aur age 24 se kam.
SELECT * 
FROM Customers 
WHERE City = 'Lahore' 
AND Age < 24;
Q14-Karachi ya Lahore ke customers.
SELECT * FROM Customers WHERE City IN ('Karachi','Lahore');
Q15-Age 21 ya 25 walay customers.
SELECT * FROM Customers WHERE Age IN (21,25);
Q16-Karachi ke ilawa tamam customers.
SELECT * FROM Customers WHERE City <> 'Karachi';
Q17-Salary 60000 nahi honi chahiye.
SELECT * FROM Customers WHERE Salary <> 60000;
